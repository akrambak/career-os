# Career-OS — credentials template
# -----------------------------------------------------------------------------
# Copy this file to .env (which is gitignored) and fill the real values:
#
#   cp .env.example .env
#
# Never commit .env. Anything in this .example file should stay as a placeholder.
# Sections are independent — fill only the ones we need for the current phase:
#
#   Phase 1 (crawler MVP):           none of these required
#   Phase 2 (applications + tracker): GITHUB_*  (for repo automation only)
#   Phase 3 (presence module):        X_*, LINKEDIN_* (heavy gotchas, see below)
#   Phase 4 (deploy + launch):        VPS_*  (only if VPS-hosted)
# =============================================================================


# === GitHub ==================================================================
# Used for: pushing repo updates, creating releases, profile README sync,
# repo-stat queries for the GitHub-optimizer module.
#
# How to create:
#   1. github.com/settings/tokens?type=beta  (Fine-grained PAT — preferred)
#   2. Resource owner: AkBak  | Expiration: 90 days
#   3. Repository access: "Only select repositories" → pick career-os
#   4. Permissions:
#        - Contents:        Read and write
#        - Metadata:        Read-only (auto)
#        - Pull requests:   Read and write
#        - Workflows:       Read and write   (only if using GitHub Actions)
#        - Profile:         Read and write   (only for profile README sync)
#   5. Copy the token (starts with github_pat_) — shown ONCE.
GITHUB_USERNAME=AkBak
GITHUB_TOKEN=github_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# === X / Twitter =============================================================
# Used for: posting build-in-public updates, threads, scheduled posts.
#
# IMPORTANT: API v2 posting requires the *Basic* tier — currently $200/month.
# Free tier is read-only (50 posts/day cap on writes for new free apps as of
# 2024-Q4 changes — verify current limits before assuming).
#
# Cheaper alternative: keep these blank and let Career-OS only DRAFT posts;
# you copy-paste manually. We can revisit if traction justifies the $200.
#
# How to create (if you do go paid):
#   1. developer.x.com → Projects & Apps → create project → app
#   2. Set User authentication settings → OAuth 1.0a → Read and write
#   3. Generate API Key + Secret  (consumer keys)
#   4. Generate Access Token + Secret  (under your @AkBak account)
#   5. (Optional) Bearer Token for read-only v2 endpoints
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_TOKEN_SECRET=
X_BEARER_TOKEN=


# === dev.to (Forem API) ======================================================
# Used for: auto-publishing weekly technical posts (Phase 1+) with
# canonical_url pointing back to bak-dev.com/blog.
#
# How to get the API key:
#   1. dev.to/settings/extensions  (must be logged in)
#   2. Section "DEV API Keys" → enter a description (e.g. "career-os") → Generate
#   3. Copy — shown ONCE.
#
# Auth: the API expects header `api-key: <token>` (NOT `Authorization: Bearer`).
# Endpoints we use:
#   POST   /api/articles           create (draft if published=false, live if true)
#   PUT    /api/articles/{id}      update
#   GET    /api/articles/me        list mine
# Free, no payment. Published posts are public; canonical_url must point to a
# URL we control on bak-dev.com.
DEVTO_API_KEY=


# === Medium ==================================================================
# Used for: auto-publishing monthly narrative posts with canonical_url back to
# bak-dev.com/blog.
#
# !!! HARD CONSTRAINT (verified 2026-05-09) !!!
# Medium STOPPED ISSUING NEW INTEGRATION TOKENS on 2026-01-01. Existing tokens
# still work indefinitely. If you do not already have one from before that
# date, you cannot get one — Medium becomes manual-paste-only for us.
#
# How to check if you have a legacy token:
#   medium.com → Settings → Security and apps → "Integration tokens" section
#   If empty: nothing to do, leave this blank, we'll generate clipboard-ready
#   markdown with a canonical_url note for you to paste manually.
#   If present: token shown there is the one to copy here.
MEDIUM_INTEGRATION_TOKEN=
MEDIUM_USER_ID=                 # auto-derived from the token via GET /v1/me, can leave blank


# === LinkedIn ================================================================
# Used for: posting articles, scheduled status updates, profile data fetch.
#
# IMPORTANT: LinkedIn does NOT have a general-purpose "post on my own behalf"
# API for individuals. Two paths:
#
#   A) Official OAuth (Sign In with LinkedIn + w_member_social scope)
#      - Requires app approval; w_member_social is restricted to specific
#        partner programs. Usually rejected for personal projects.
#      - If approved, fill LINKEDIN_CLIENT_ID/SECRET + run OAuth flow to get
#        LINKEDIN_ACCESS_TOKEN (60-day expiry, must be refreshed).
#
#   B) Unofficial (linkedin-api Python lib — uses your session cookie)
#      - Works today, against ToS. Risk of account flag if heavy usage.
#      - You'd export the `li_at` cookie from a logged-in browser session.
#
# Recommended for now: leave blank, draft posts to clipboard, paste manually.
# Revisit when content cadence proves the automation is worth the friction.
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_LI_AT_COOKIE=


# === VPS / website host ======================================================
# Used for: deploying Career-OS dashboard backend, running the always-on
# crawler cron, deploying bak-dev.com updates.
#
# If bak-dev.com is on Vercel / Netlify / Cloudflare Pages → SKIP this section,
# we'll use git-push + deploy hooks instead. Tell me which host it's on.
#
# If you have a real VPS (Hetzner, OVH, DigitalOcean, etc.):
#   1. Generate a dedicated key for Career-OS (don't reuse your personal key):
#        ssh-keygen -t ed25519 -f ~/.ssh/career_os -C "career-os@bak-dev.com"
#      Press enter twice for no passphrase (or set one and use ssh-agent).
#   2. Copy the public key to the VPS:
#        ssh-copy-id -i ~/.ssh/career_os.pub VPS_USER@VPS_HOST
#   3. Test:
#        ssh -i ~/.ssh/career_os VPS_USER@VPS_HOST 'echo ok'
#   4. Fill the values below — VPS_SSH_KEY_PATH is the *private* key path on
#      this machine. The key file itself stays in ~/.ssh, NOT in this repo.
VPS_HOST=
VPS_USER=
VPS_PORT=22
VPS_SSH_KEY_PATH=/home/ultra9-ubuntu/.ssh/career_os

# Where the deployed dashboard / crawler will live on the VPS:
VPS_APP_DIR=/srv/career-os

# If bak-dev.com is on a managed host instead of a VPS, fill ONE of these
# instead of the VPS_* block above and I'll script the right deploy path:
WEBSITE_HOST_PROVIDER=          # vercel | netlify | cloudflare-pages | other
WEBSITE_DEPLOY_HOOK_URL=        # for git-less redeploys (Vercel/Netlify/CF)


# === Anthropic (Claude SDK) ==================================================
# Used for: the scoring + drafting agents at the heart of Career-OS.
# console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# === SMTP (for daily job digest emails) ======================================
# Used for: daily "top 5 jobs" email digest from the crawler.
# Easiest: a transactional service (Resend, Postmark) — single API key.
# Or use Gmail with an App Password (16-char, requires 2FA on the account).
SMTP_PROVIDER=                  # resend | postmark | gmail
SMTP_API_KEY=
SMTP_FROM=me@bak-dev.com
SMTP_TO=me@bak-dev.com
