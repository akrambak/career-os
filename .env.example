# Career-OS — credentials template
# -----------------------------------------------------------------------------
# Copy this file to .env (which is gitignored) and fill the real values:
#
#   cp .env.example .env
#
# Never commit .env. Anything in this .example file should stay as a placeholder.
#
# Channel decisions (locked 2026-05-09):
#   GitHub      → automated  (PAT)
#   dev.to      → automated  (free API)
#   Anthropic   → automated  (API key)
#   LinkedIn    → automated  (UNOFFICIAL — li_at session cookie via linkedin-api lib)
#   VPS         → SSH key auth (Debian VPS hosts both bak-dev.com and Career-OS)
#   X / Twitter → MANUAL     (no API spend; Career-OS drafts → you paste)
#   Medium      → MANUAL     (no API spend; clipboard-formatted markdown → you paste)
#   SMTP        → automated  (transactional provider for daily digest)
# =============================================================================


# === GitHub ==================================================================
# Used for: pushing repo updates, creating releases, profile README sync,
# repo-stat queries for the GitHub-optimizer module.
#
# How to create:
#   1. github.com/settings/tokens?type=beta  (Fine-grained PAT — preferred)
#   2. Resource owner: AkBak  | Expiration: 90 days
#   3. Repository access: "Only select repositories" → pick career-os
#   4. Permissions:
#        - Contents:        Read and write
#        - Metadata:        Read-only (auto)
#        - Pull requests:   Read and write
#        - Workflows:       Read and write   (only if using GitHub Actions)
#        - Profile:         Read and write   (only for profile README sync)
#   5. Copy the token (starts with github_pat_) — shown ONCE.
GITHUB_USERNAME=AkBak
GITHUB_TOKEN=


# === dev.to (Forem API) ======================================================
# Used for: auto-publishing weekly technical posts (Phase 1+) with
# canonical_url pointing back to bak-dev.com/blog.
#
# How to get the API key:
#   1. dev.to/settings/extensions  (must be logged in)
#   2. Section "DEV API Keys" → enter a description (e.g. "career-os") → Generate
#   3. Copy — shown ONCE.
#
# Auth: the API expects header `api-key: <token>` (NOT `Authorization: Bearer`).
# Endpoints we use: POST /api/articles, PUT /api/articles/{id}, GET /api/articles/me
# Free, no payment.
DEVTO_API_KEY=


# === LinkedIn (UNOFFICIAL — li_at session cookie) ============================
# Decision (2026-05-09): cookie-based path via the `linkedin-api` Python lib
# (Voyager API). This is AGAINST LinkedIn's ToS — risk of account flag if
# usage looks automated. Mitigations are baked into the Career-OS adapter:
#   - Posts originate from a residential IP (your machine), not the VPS.
#     The Debian VPS runs everything else, but the LinkedIn poster is
#     pinned to local + cron / scheduled wakeup.
#   - Human-like timing jitter (no exact-on-the-hour posting).
#   - Cadence cap: ≤ 3 posts/week, ≤ 1/day.
#   - Hard fallback: if any auth call returns 401/CHALLENGE, the adapter
#     downgrades to clipboard mode and emails you to refresh the cookie.
#
# How to extract the cookies:
#   1. Open linkedin.com in your normal browser, log in fully (resolve any
#      checkpoints first — you want a clean session).
#   2. DevTools → Application → Storage → Cookies → https://www.linkedin.com
#   3. Copy the *Value* of these three cookies into the .env:
#        - li_at        (primary auth — the long one, ~150 chars)
#        - JSESSIONID   (CSRF; strip the surrounding quotes if any)
#        - bcookie      (browser fingerprint match — reduces flag risk)
#   4. Cookie lifetime: nominally 1 year, but in practice rotates whenever
#      LinkedIn feels like it. Plan to refresh on any auth failure.
#
# Optional: LINKEDIN_USER_AGENT — if blank, the adapter uses a recent
# Chrome UA. Set it to YOUR browser's UA string for maximum fingerprint
# alignment with the session that minted the cookie (lowest flag risk).
LINKEDIN_LI_AT=
LINKEDIN_JSESSIONID=
LINKEDIN_BCOOKIE=
LINKEDIN_USER_AGENT=


# === X / Twitter — MANUAL ====================================================
# Decision (2026-05-09): manual posting only. No API spend.
# Career-OS will generate thread-formatted drafts to clipboard / file; user
# pastes them into x.com manually. No env values needed.
# If this changes later, add back X_API_KEY / X_API_SECRET / X_ACCESS_TOKEN /
# X_ACCESS_TOKEN_SECRET / X_BEARER_TOKEN — see git history for the spec.


# === Medium — MANUAL =========================================================
# Decision (2026-05-09): manual posting only. (Medium also stopped issuing new
# integration tokens on 2026-01-01, so this is also the only available path
# for users without a legacy token.)
# Career-OS will generate clipboard-ready markdown with a footer note
# reminding to set canonical_url under Story Settings → Advanced.


# === Debian VPS (hosts bak-dev.com + Career-OS backend) ======================
# Used for: deploying bak-dev.com (Next.js), running the always-on crawler
# cron, hosting the Career-OS dashboard backend.
#
# Setup steps on this machine:
#   1. Generate a dedicated key (don't reuse a personal key):
#        ssh-keygen -t ed25519 -f ~/.ssh/career_os -C "career-os@bak-dev.com"
#      Press enter twice for no passphrase (or set one + use ssh-agent).
#   2. Append the public key to the VPS:
#        ssh-copy-id -i ~/.ssh/career_os.pub VPS_USER@VPS_HOST
#      (or paste ~/.ssh/career_os.pub into ~/.ssh/authorized_keys on the VPS)
#   3. Test:
#        ssh -i ~/.ssh/career_os VPS_USER@VPS_HOST 'uname -a && df -h /'
#   4. Fill the values below.
# VPS_SSH_KEY_PATH points to the *private* key on THIS machine; the key file
# itself stays in ~/.ssh and is never copied into this repo.
VPS_HOST=                       # hostname or IP (e.g. vps.bak-dev.com or 1.2.3.4)
VPS_USER=                       # the linux user on the VPS (root, deploy, etc.)
VPS_PORT=22
VPS_SSH_KEY_PATH=/home/ultra9-ubuntu/.ssh/career_os

# Filesystem layout on the VPS (will be created on first deploy):
VPS_SITE_DIR=/srv/bak-dev.com   # Next.js site for bak-dev.com
VPS_APP_DIR=/srv/career-os      # Career-OS backend (crawler, agents, dashboard API)


# === Anthropic (Claude SDK) ==================================================
# Used for: the scoring + drafting agents at the heart of Career-OS.
# console.anthropic.com → Settings → API Keys
ANTHROPIC_API_KEY=


# === SMTP (for daily job digest emails) ======================================
# Used for: daily "top 5 jobs" email digest from the crawler.
# Easiest: a transactional service (Resend, Postmark) — single API key.
# Or use Gmail with an App Password (16-char, requires 2FA on the account).
SMTP_PROVIDER=                  # resend | postmark | gmail
SMTP_API_KEY=
SMTP_FROM=me@bak-dev.com
SMTP_TO=me@bak-dev.com
